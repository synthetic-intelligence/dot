#!/usr/bin/env bash
set -euo pipefail
# set -x

# Script to execute commands from a choices file
# Usage: script.sh [-f filename] [choice_number] [additional_args...]

readonly DEFAULT_FILENAME=".choices"
filename="$DEFAULT_FILENAME"

# Parse -f flag for custom filename
if [[ "${1:-}" == "-f" ]]; then
    if [[ -z "${2:-}" ]]; then
        echo "Error: -f requires a filename argument" >&2
        exit 1
    fi
    filename="$2"
    shift 2
fi

# Find the choices file if it's not directly readable
if [[ ! -r "$filename" ]]; then
    prefix="."
    found=false
    
    while true; do
        absolute=$(cd "$prefix" && pwd)
        
        if [[ -r "$absolute/$DEFAULT_FILENAME" ]]; then
            filename="$absolute/$DEFAULT_FILENAME"
            found=true
            break
        fi
        
        if [[ "$absolute" == "/" ]]; then
            break
        fi
        
        prefix="$prefix/.."
    done
    
    if [[ "$found" == false ]]; then
        echo "Error: No $DEFAULT_FILENAME file found" >&2
        exit 1
    fi
fi

# Verify the file is readable
if [[ ! -r "$filename" ]]; then
    echo "Error: Cannot read file: $filename" >&2
    exit 1
fi

# If user pre-supplied a choice number, use it directly
if [[ -n "${1:-}" && "$1" =~ ^[0-9]+$ ]]; then
    choice_num="$1"
    shift
    
    # Get the command at the specified line
    command=$(sed -n "${choice_num}p" "$filename")
    
    if [[ -z "$command" ]]; then
        echo "Error: No command found at line $choice_num" >&2
        exit 1
    fi
    
    echo "$command $*"
    eval "$command $*"
    exit 0
fi

# Present interactive menu
IFS=$'\n'
PS3="Enter choice number (or 'q' to quit): "
select choice in $(cat "$filename"); do
    # Check if user wants to quit
    if [[ "$REPLY" == "q" || "$REPLY" == "Q" ]]; then
        echo "Quitting..."
        exit 0
    fi
    
    if [[ -n "$choice" ]]; then
        # Add to bash history
        history -s "$choice"
        
        # Execute the chosen command with any additional arguments
        eval "$choice $*"
        break
    else
        echo "Invalid selection" >&2
    fi
done
