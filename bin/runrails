#! /usr/bin/env -S bash -e

git pull

bundle install

if [[ ! -e db/development.sqlite3 ]]
then
    echo "migrating development"
    ./bin/rails db:migrate
    ./bin/rails db:seed
else
    echo "using db/development.sqlite3"
fi

if [[ ! -e db/test.sqlite3 ]]
then
    echo "migrating test"
    ./bin/rails db:migrate RAILS_ENV=test
fi

# bin/rails tmp:clear
./bin/rails test
# rails test:system
# bin/rails tmp:clear
./bin/rails server
